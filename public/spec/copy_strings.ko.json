  "email_templates": {
    "new_order_operator": {
      "subject": "[진장키친] 신규 주문이 접수되었습니다 — {{short_id}}",
      "text": "안녕하세요, 운영자님.\n\n신규 주문이 접수되었습니다.\n\n주문번호: {{short_id}}\n고객명: {{customer_name}}\n전화번호: {{customer_phone}}\n배송 주소: {{address}} ({{district}})\n배송 슬롯: {{slot_text}}\n결제 수단: {{payment_method}}\n합계: {{total_vnd}}\n\n주문 관리 페이지에서 확인하고 수락해 주세요:\n{{admin_url}}\n\n진장키친 시스템 발송",
      "html": "<!DOCTYPE html><html><body style='font-family:sans-serif;background:#FFFBF5;padding:24px'><div style='max-width:480px;margin:0 auto;background:#fff;border-radius:14px;border:1px solid #E8D9C5;overflow:hidden'><div style='background:#8B5E34;padding:20px 24px'><h2 style='color:#fff;margin:0;font-size:18px'>Jin Jang's Kitchen</h2><p style='color:#E8D9C5;margin:4px 0 0;font-size:13px'>신규 주문 알림</p></div><div style='padding:24px'><p style='color:#111827;font-size:15px;margin:0 0 16px'>신규 주문이 접수되었습니다.</p><table style='width:100%;border-collapse:collapse'><tr><td style='padding:8px 0;color:#6B7280;font-size:13px;border-bottom:1px solid #E8D9C5'>주문번호</td><td style='padding:8px 0;font-weight:600;font-size:13px;border-bottom:1px solid #E8D9C5'>{{short_id}}</td></tr><tr><td style='padding:8px 0;color:#6B7280;font-size:13px;border-bottom:1px solid #E8D9C5'>고객명</td><td style='padding:8px 0;font-size:13px;border-bottom:1px solid #E8D9C5'>{{customer_name}}</td></tr><tr><td style='padding:8px 0;color:#6B7280;font-size:13px;border-bottom:1px solid #E8D9C5'>전화</td><td style='padding:8px 0;font-size:13px;border-bottom:1px solid #E8D9C5'>{{customer_phone}}</td></tr><tr><td style='padding:8px 0;color:#6B7280;font-size:13px;border-bottom:1px solid #E8D9C5'>주소</td><td style='padding:8px 0;font-size:13px;border-bottom:1px solid #E8D9C5'>{{address}} ({{district}})</td></tr><tr><td style='padding:8px 0;color:#6B7280;font-size:13px;border-bottom:1px solid #E8D9C5'>슬롯</td><td style='padding:8px 0;font-size:13px;border-bottom:1px solid #E8D9C5'>{{slot_text}}</td></tr><tr><td style='padding:8px 0;color:#6B7280;font-size:13px;border-bottom:1px solid #E8D9C5'>합계</td><td style='padding:8px 0;font-weight:700;color:#8B5E34;font-size:14px;border-bottom:1px solid #E8D9C5'>{{total_vnd}}</td></tr></table><a href='{{admin_url}}' style='display:inline-block;margin-top:20px;background:#8B5E34;color:#fff;padding:12px 24px;border-radius:10px;text-decoration:none;font-weight:600;font-size:14px'>주문 확인하기</a></div><div style='padding:12px 24px;background:#F5EDE0;font-size:11px;color:#6B7280'>진장키친 자동 발송 메일입니다.</div></div></body></html>"
    },
    "status_change_customer": {
      "subject": "[진장키친] 주문 {{short_id}} 상태가 변경되었습니다",
      "text": "안녕하세요, {{customer_name}}님.\n\n주문 {{short_id}}의 상태가 [{{new_status}}](으)로 변경되었습니다.\n\n슬롯: {{slot_text}}\n합계: {{total_vnd}}\n\n문의: {{support_email}}\n\n감사합니다, 진장키친",
      "html": "<!DOCTYPE html><html><body style='font-family:sans-serif;background:#FFFBF5;padding:24px'><div style='max-width:480px;margin:0 auto;background:#fff;border-radius:14px;border:1px solid #E8D9C5;overflow:hidden'><div style='background:#8B5E34;padding:20px 24px'><h2 style='color:#fff;margin:0;font-size:18px'>Jin Jang's Kitchen</h2></div><div style='padding:24px'><p style='color:#111827;font-size:15px'>안녕하세요, <strong>{{customer_name}}</strong>님.</p><p style='color:#111827;font-size:14px'>주문 <strong>{{short_id}}</strong>의 상태가 변경되었습니다.</p><div style='background:#F5EDE0;border-radius:10px;padding:16px;margin:16px 0;text-align:center'><span style='font-size:18px;font-weight:700;color:#8B5E34'>{{new_status}}</span></div><p style='color:#6B7280;font-size:13px'>슬롯: {{slot_text}}<br>합계: {{total_vnd}}</p><p style='color:#6B7280;font-size:12px;margin-top:16px'>문의: <a href='mailto:{{support_email}}' style='color:#8B5E34'>{{support_email}}</a></p></div></div></body></html>"
    },
    "cancel_customer": {
      "subject": "[진장키친] 주문 {{short_id}} 취소 안내",
      "text": "안녕하세요, {{customer_name}}님.\n\n주문 {{short_id}}이 취소되었습니다.\n\n취소 사유: {{cancel_reason}}\n\n환불 안내: 계좌이체 결제건은 영업일 3–5일 내 환불 처리됩니다. 착불(COD) 결제건은 별도 환불이 발생하지 않습니다.\n\n문의: {{support_email}}\n\n불편을 드려 죄송합니다, 진장키친",
      "html": "<!DOCTYPE html><html><body style='font-family:sans-serif;background:#FFFBF5;padding:24px'><div style='max-width:480px;margin:0 auto;background:#fff;border-radius:14px;border:1px solid #E8D9C5;overflow:hidden'><div style='background:#B42318;padding:20px 24px'><h2 style='color:#fff;margin:0;font-size:18px'>Jin Jang's Kitchen — 주문 취소</h2></div><div style='padding:24px'><p style='color:#111827;font-size:15px'>안녕하세요, <strong>{{customer_name}}</strong>님.</p><p style='color:#111827;font-size:14px'>주문 <strong>{{short_id}}</strong>이 취소되었습니다.</p><div style='background:#FEF2F2;border:1px solid #FECACA;border-radius:10px;padding:16px;margin:16px 0'><p style='color:#B91C1C;font-size:13px;margin:0'><strong>취소 사유:</strong> {{cancel_reason}}</p></div><div style='background:#F5EDE0;border-radius:10px;padding:14px;margin:12px 0'><p style='color:#8B5E34;font-size:13px;margin:0'>환불 안내: 계좌이체 결제건은 영업일 3–5일 내 환불 처리됩니다.</p></div><p style='color:#6B7280;font-size:12px;margin-top:16px'>문의: <a href='mailto:{{support_email}}' style='color:#8B5E34'>{{support_email}}</a></p></div></div></body></html>"
    }
  }
